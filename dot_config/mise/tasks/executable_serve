#!/usr/bin/env bash
#MISE description="Serve current directory over HTTP"
#MISE dir="{{cwd}}"
#USAGE flag "-p --port <port>" help="Port to listen on"
#USAGE flag "-b --bind <addr>" help="Bind address (default 127.0.0.1)"

set -euo pipefail

PORT="${usage_port:-8000}"
BIND="${usage_bind:-127.0.0.1}"

echo "serving $(pwd) on http://${BIND}:${PORT}"
exec python3 -m http.server "$PORT" --bind "$BIND"