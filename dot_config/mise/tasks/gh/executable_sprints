#!/usr/bin/env bash
#MISE description="Topologically sorted execution order for a milestone sprint"
#MISE alias="ghsp"
#MISE dir="{{cwd}}"
#USAGE arg "<milestone>" help="Milestone title or number (e.g. 'Sprint 1' or 1)"
#USAGE flag "--json"  help="Output as JSON"
#USAGE flag "--open"  help="Only include open issues (default: all)"
set -euo pipefail

GH_JSON_FIELDS="number,title,state,url,milestone,labels,body"

# ──────────────────────────────────────────────
# Graph building (inlined from gh-blockers)
# ──────────────────────────────────────────────

build_graph() {
  local issues_json="$1"
  jq '
    # Build logical-to-github-number map from [X.Y] title prefixes
    # e.g. "[1.3] Define..." -> {"1.3": 13}
    (map({
      key:   (.title | ltrimstr("[") | split("]")[0]),
      value: .number
    })
    | map(select(.key | test("^[0-9]+(\\.[0-9]+)+")))
    | map({(.key): .value})
    | add // {}) as $lmap |

    map({
      number:    .number,
      title:     .title,
      state:     .state,
      url:       .url,
      labels:    [.labels[].name],
      blockedBy: (
        [ .body
          | scan("(?i)blocked by[^\n]*")
          | scan("#[0-9]+(?:\\.[0-9]+)?")
          | ltrimstr("#")
          | if test("\\.")
            then ($lmap[.] // empty)
            else tonumber
            end
        ] | unique | sort
      ),
      blocks: (
        [ .body
          | scan("(?i)\\bblocks[^\n]*")
          | scan("#[0-9]+(?:\\.[0-9]+)?")
          | ltrimstr("#")
          | if test("\\.")
            then ($lmap[.] // empty)
            else tonumber
            end
        ] | unique | sort
      )
    })
  ' <<< "$issues_json"
}

# ──────────────────────────────────────────────
# Topological sort — Kahn's algorithm in bash
# Edges are filtered to in-set only so external
# deps don't inflate in-degree and break the sort.
# ──────────────────────────────────────────────

topo_sort() {
  local graph_json="$1"

  # Build membership set
  declare -A in_set
  while IFS= read -r n; do in_set[$n]=1; done \
    < <(jq -r '.[].number' <<< "$graph_json")

  # in_degree[n]  = number of in-set blockers for n
  # adj[n]        = space-separated list of in-set nodes that n unblocks
  declare -A in_degree adj
  while IFS= read -r n; do
    in_degree[$n]=0
    adj[$n]=""
  done < <(jq -r '.[].number' <<< "$graph_json")

  while IFS= read -r row; do
    local num
    num=$(jq -r '.number' <<< "$row")
    while IFS= read -r blocker; do
      [[ -z "$blocker" ]] && continue
      if [[ -n "${in_set[$blocker]:-}" ]]; then
        in_degree[$num]=$(( in_degree[$num] + 1 ))
        adj[$blocker]="${adj[$blocker]} $num"
      fi
    done < <(jq -r '.blockedBy[]' <<< "$row" 2>/dev/null || true)
  done < <(jq -c '.[]' <<< "$graph_json")

  # Seed queue with zero-in-degree nodes (sorted for determinism)
  local queue=()
  mapfile -t queue < <(
    for n in "${!in_degree[@]}"; do
      [[ "${in_degree[$n]}" -eq 0 ]] && echo "$n"
    done | sort -n
  )

  local result=()
  local orphans=()

  while [[ ${#queue[@]} -gt 0 ]]; do
    local node="${queue[0]}"
    queue=("${queue[@]:1}")

    # Orphan: no in-set blockers AND blocks nothing in-set
    if [[ -z "${adj[$node]}" ]]; then
      orphans+=("$node")
    else
      result+=("$node")
    fi

    for neighbor in ${adj[$node]:-}; do
      [[ -z "$neighbor" ]] && continue
      in_degree[$neighbor]=$(( in_degree[$neighbor] - 1 ))
      if [[ "${in_degree[$neighbor]}" -eq 0 ]]; then
        queue+=("$neighbor")
        mapfile -t queue < <(printf "%s\n" "${queue[@]}" | sort -n)
      fi
    done
  done

  # Cycle detection — any node not yet emitted
  local cycles=()
  for n in "${!in_degree[@]}"; do
    if [[ "${in_degree[$n]}" -gt 0 ]]; then
      cycles+=("$n")
    fi
  done

  # Safe array-to-JSON — guards against empty arrays blowing up jq -R 'tonumber'
  local order_json orphans_json cycles_json
  if [[ ${#result[@]} -gt 0 ]]; then
    order_json=$(printf '%s\n' "${result[@]}"  | jq -R 'tonumber' | jq -s '.')
  else
    order_json='[]'
  fi
  if [[ ${#orphans[@]} -gt 0 ]]; then
    orphans_json=$(printf '%s\n' "${orphans[@]}" | jq -R 'tonumber' | jq -s '.')
  else
    orphans_json='[]'
  fi
  if [[ ${#cycles[@]} -gt 0 ]]; then
    cycles_json=$(printf '%s\n' "${cycles[@]}"  | jq -R 'tonumber' | jq -s '.')
  else
    cycles_json='[]'
  fi

  jq -n \
    --argjson order   "$order_json" \
    --argjson orphans "$orphans_json" \
    --argjson cycles  "$cycles_json" \
    '{order: $order, orphans: $orphans, cycles: $cycles}'
}

# ──────────────────────────────────────────────
# Output
# ──────────────────────────────────────────────

print_pretty() {
  local sort_json="$1"
  local graph_json="$2"
  local milestone="$3"

  # Index graph by number for fast lookup
  local index
  index=$(jq 'map({(.number | tostring): .}) | add' <<< "$graph_json")

  local order orphans cycles
  order=$(jq  '.order'   <<< "$sort_json")
  orphans=$(jq '.orphans' <<< "$sort_json")
  cycles=$(jq  '.cycles'  <<< "$sort_json")

  printf "\033[1;36m Sprint: %s\033[0m\n" "$milestone"

  # Execution order
  local order_len
  order_len=$(jq 'length' <<< "$order")
  printf "\n\033[1m━━━ Execution order\033[0m \033[2m(%s issues)\033[0m\n" "$order_len"

  if [[ "$order_len" -eq 0 ]]; then
    printf "  \033[2mnone\033[0m\n"
  else
    local step=1
    while IFS= read -r num; do
      local title state labels blocked_by
      title=$(jq -r --arg n "$num" '.[$n].title'  <<< "$index")
      state=$(jq -r --arg n "$num" '.[$n].state'  <<< "$index")
      labels=$(jq -r --arg n "$num" '[.[$n].labels[]] | join(", ")' <<< "$index")
      blocked_by=$(jq -r --arg n "$num" '.[$n].blockedBy | map("#\(.)") | join(", ")' <<< "$index")

      local state_colour='\033[1;32m'
      [[ "$state" == "CLOSED" ]] && state_colour='\033[2m'

      printf "${state_colour}%2d.\033[0m  \033[1;36m#%s\033[0m  %s\n" "$step" "$num" "$title"
      [[ -n "$labels"     ]] && printf "      \033[2mlabels:     %s\033[0m\n" "$labels"
      [[ -n "$blocked_by" && "$blocked_by" != "" ]] && \
        printf "      \033[33m⬆ blocked by: %s\033[0m\n" "$blocked_by"
      echo

      (( step++ ))
    done < <(jq -r '.[]' <<< "$order")
  fi

  # Orphans
  local orphan_len
  orphan_len=$(jq 'length' <<< "$orphans")
  printf "\033[1m━━━ Parallelisable\033[0m \033[2m(%s — no deps in sprint)\033[0m\n" "$orphan_len"

  if [[ "$orphan_len" -eq 0 ]]; then
    printf "  \033[2mnone\033[0m\n"
  else
    while IFS= read -r num; do
      local title labels
      title=$(jq -r --arg n "$num" '.[$n].title'  <<< "$index")
      labels=$(jq -r --arg n "$num" '[.[$n].labels[]] | join(", ")' <<< "$index")
      printf "  \033[1;35m#%s\033[0m  %s\n" "$num" "$title"
      [[ -n "$labels" ]] && printf "  \033[2m%s\033[0m\n" "$labels"
      echo
    done < <(jq -r '.[]' <<< "$orphans")
  fi

  # Cycles — shouldn't happen with clean issue hygiene but call it out loudly
  local cycle_len
  cycle_len=$(jq 'length' <<< "$cycles")
  if [[ "$cycle_len" -gt 0 ]]; then
    printf "\033[1;31m━━━ Cycles detected ━━━\033[0m\n"
    printf "\033[31mThese issues form a dependency cycle and cannot be ordered:\033[0m\n"
    while IFS= read -r num; do
      local title
      title=$(jq -r --arg n "$num" '.[$n].title' <<< "$index")
      printf "  \033[1;31m#%s\033[0m  %s\n" "$num" "$title"
    done < <(jq -r '.[]' <<< "$cycles")
    echo
  fi
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

main() {
  local milestone=""
  local json=false
  local open_only=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)  json=true;      shift ;;
      --open)  open_only=true; shift ;;
      -*)  echo "error: unknown flag: '$1'" >&2; exit 1 ;;
      *)   milestone="$1";     shift ;;
    esac
  done

  if [[ -z "$milestone" ]]; then
    echo "error: milestone required (e.g. 'Sprint 1')" >&2
    exit 1
  fi

  local state_flag="all"
  [[ "$open_only" == "true" ]] && state_flag="open"

  # Fetch all issues for the milestone
  local numbers_json
  numbers_json=$(gh issue list \
    --milestone "$milestone" \
    --state "$state_flag" \
    --json number \
    --limit 200 \
    --jq '[.[].number]')

  if [[ "$numbers_json" == "[]" ]]; then
    echo "error: no issues found for milestone '$milestone'" >&2
    exit 1
  fi

  # Fetch full issue data
  local issues_json
  issues_json=$(
    jq -r '.[]' <<< "$numbers_json" | while IFS= read -r num; do
      gh issue view "$num" --json "$GH_JSON_FIELDS"
    done | jq -s '.'
  )

  local graph_json sort_json
  graph_json=$(build_graph "$issues_json")
  sort_json=$(topo_sort "$graph_json")

  if [[ "$json" == "true" ]]; then
    jq -n \
      --arg     milestone "$milestone" \
      --argjson graph     "$graph_json" \
      --argjson sort      "$sort_json" \
      '{milestone: $milestone, graph: $graph, sort: $sort}'
    return
  fi

  print_pretty "$sort_json" "$graph_json" "$milestone"
}

main "$@"