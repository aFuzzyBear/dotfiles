#!/usr/bin/env bash
#MISE description="Standup digest — issues and PRs you touched in the last N hours"
#MISE alias="ghst"
#MISE dir="{{cwd}}"
#USAGE flag "--since <duration>" help="Lookback window: 24h, 48h, 7d (default: 24h)"
#USAGE flag "--json"             help="Output as JSON"
set -euo pipefail

# ──────────────────────────────────────────────
# Time helpers
# ──────────────────────────────────────────────

# Parse a duration string (24h, 48h, 7d) into seconds
parse_duration() {
  local raw="$1"
  local num unit
  num="${raw//[^0-9]/}"
  unit="${raw//[0-9]/}"
  case "$unit" in
    h) echo $(( num * 3600 )) ;;
    d) echo $(( num * 86400 )) ;;
    w) echo $(( num * 604800 )) ;;
    *) echo "error: unrecognised duration unit '$unit' — use h, d, or w" >&2; exit 1 ;;
  esac
}

# ISO-8601 cutoff timestamp for jq filtering
cutoff_iso() {
  local seconds_ago="$1"
  date -u -d "@$(( $(date +%s) - seconds_ago ))" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null \
    || date -u -v "-${seconds_ago}S" '+%Y-%m-%dT%H:%M:%SZ'  # macOS fallback
}

# ──────────────────────────────────────────────
# Fetch + filter
# ──────────────────────────────────────────────

fetch_issues() {
  local cutoff="$1"
  gh issue list \
    --assignee "@me" \
    --state all \
    --json number,title,state,url,updatedAt,labels,milestone \
    --limit 100 \
    | jq --arg cutoff "$cutoff" '
        map(select(.updatedAt >= $cutoff))
        | sort_by(.updatedAt) | reverse
      '
}

fetch_my_prs() {
  local cutoff="$1"
  gh pr list \
    --author "@me" \
    --state all \
    --json number,title,state,isDraft,url,updatedAt,headRefName,mergeStateStatus \
    --limit 50 \
    | jq --arg cutoff "$cutoff" '
        map(select(.updatedAt >= $cutoff))
        | sort_by(.updatedAt) | reverse
      '
}

fetch_reviewed_prs() {
  local cutoff="$1"
  gh pr list \
    --search "reviewed-by:@me -author:@me" \
    --state all \
    --json number,title,state,author,url,updatedAt \
    --limit 50 \
    | jq --arg cutoff "$cutoff" '
        map(select(.updatedAt >= $cutoff))
        | sort_by(.updatedAt) | reverse
      '
}

# ──────────────────────────────────────────────
# Pretty output
# ──────────────────────────────────────────────

print_section() {
  local title="$1" count="$2"
  printf "\n\033[1m━━━ %s\033[0m \033[2m(%s)\033[0m\n" "$title" "$count"
}

print_issues() {
  local json="$1"
  local count; count=$(jq 'length' <<< "$json")
  print_section "Issues" "$count"
  [[ "$count" -eq 0 ]] && { printf "  \033[2mnone\033[0m\n"; return; }

  jq -r '.[] |
    (if .state == "CLOSED" then "\u001b[2m" else "\u001b[1;36m" end) +
    "#\(.number)\u001b[0m  \(.title)" +
    "  \u001b[2m[\(.state)]" +
    (if .milestone then " · \(.milestone.title)" else "" end) +
    "\u001b[0m"
  ' <<< "$json"
}

print_my_prs() {
  local json="$1"
  local count; count=$(jq 'length' <<< "$json")
  print_section "My PRs" "$count"
  [[ "$count" -eq 0 ]] && { printf "  \033[2mnone\033[0m\n"; return; }

  jq -r '.[] |
    (if   .state == "MERGED" then "\u001b[35m"
     elif .state == "CLOSED" then "\u001b[2m"
     elif .isDraft           then "\u001b[33m"
     else                        "\u001b[1;35m"
     end) +
    "#\(.number)\u001b[0m  \(.title)" +
    "  \u001b[2m[\(.state)" +
    (if .isDraft then " · draft" else "" end) +
    (if .mergeStateStatus == "CLEAN" and .state == "OPEN" then " · ✓ mergeable" else "" end) +
    "]\u001b[0m"
  ' <<< "$json"
}

print_reviews() {
  local json="$1"
  local count; count=$(jq 'length' <<< "$json")
  print_section "Reviews" "$count"
  [[ "$count" -eq 0 ]] && { printf "  \033[2mnone\033[0m\n"; return; }

  jq -r '.[] |
    "\u001b[1;33m#\(.number)\u001b[0m  \(.title)" +
    "  \u001b[2mby \(.author.login) · [\(.state)]\u001b[0m"
  ' <<< "$json"
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

main() {
  local since="24h"
  local json=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)    since="$2";  shift 2 ;;
      --since=*)  since="${1#--since=}"; shift ;;
      --json)     json=true;   shift ;;
      -*) echo "error: unknown flag: '$1'" >&2; exit 1 ;;
      *)  echo "error: unexpected argument: '$1'" >&2; exit 1 ;;
    esac
  done

  local seconds cutoff
  seconds=$(parse_duration "$since")
  cutoff=$(cutoff_iso "$seconds")

  local issues_json my_prs_json reviews_json
  issues_json=$(fetch_issues  "$cutoff")
  my_prs_json=$(fetch_my_prs  "$cutoff")
  reviews_json=$(fetch_reviewed_prs "$cutoff")

  if [[ "$json" == "true" ]]; then
    jq -n \
      --arg     since   "$since" \
      --arg     cutoff  "$cutoff" \
      --argjson issues  "$issues_json" \
      --argjson myPrs   "$my_prs_json" \
      --argjson reviews "$reviews_json" \
      '{since: $since, cutoff: $cutoff, issues: $issues, myPrs: $myPrs, reviews: $reviews}'
    return
  fi

  local total=$(( $(jq 'length' <<< "$issues_json") + $(jq 'length' <<< "$my_prs_json") + $(jq 'length' <<< "$reviews_json") ))

  printf "\033[1;36mStandup\033[0m  \033[2mlast %s · %s items\033[0m" "$since" "$total"

  print_issues  "$issues_json"
  print_my_prs  "$my_prs_json"
  print_reviews "$reviews_json"

  echo
}

main "$@"