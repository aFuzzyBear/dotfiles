#!/usr/bin/env bash
#MISE description="Show failed step logs for the latest (or specified) workflow run"
#MISE alias="ghrl"
#MISE dir="{{cwd}}"
#USAGE arg "[run_id]" help="Workflow run ID (defaults to latest on current branch)"
#USAGE flag "--all"    help="Show all steps, not just failures"
#USAGE flag "--branch <branch>" help="Target branch (defaults to current)"
set -euo pipefail

# ──────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────

current_branch() {
  git rev-parse --abbrev-ref HEAD 2>/dev/null || {
    echo "error: not inside a git repository" >&2; exit 1
  }
}

resolve_run_id() {
  local branch="$1"
  local run_id
  run_id=$(gh run list --branch "$branch" --limit 1 --json databaseId --jq '.[0].databaseId // empty')
  if [[ -z "$run_id" ]]; then
    echo "error: no workflow runs found for branch '$branch'" >&2
    exit 1
  fi
  echo "$run_id"
}

print_run_summary() {
  local run_json="$1"
  local status conclusion name created
  status=$(jq -r '.status'     <<< "$run_json")
  conclusion=$(jq -r '.conclusion // "in_progress"' <<< "$run_json")
  name=$(jq -r '.name'         <<< "$run_json")
  created=$(jq -r '.createdAt' <<< "$run_json")

  local colour
  case "$conclusion" in
    success)            colour='\033[1;32m' ;;
    failure|cancelled)  colour='\033[1;31m' ;;
    *)                  colour='\033[1;33m' ;;
  esac

  printf "${colour}[%s]${RESET}  %s  \033[2m%s\033[0m\n\n" \
    "$conclusion" "$name" "$created"
}

RESET='\033[0m'

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

main() {
  local run_id=""
  local show_all=false
  local branch=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all)          show_all=true; shift ;;
      --branch)       branch="$2";   shift 2 ;;
      --branch=*)     branch="${1#--branch=}"; shift ;;
      -*) echo "error: unknown flag: '$1'" >&2; exit 1 ;;
      *)  run_id="$1"; shift ;;
    esac
  done

  if [[ -z "$branch" ]]; then
    branch="$(current_branch)"
  fi

  if [[ -z "$run_id" ]]; then
    run_id="$(resolve_run_id "$branch")"
  fi

  # Run-level summary
  local run_json
  run_json="$(gh run view "$run_id" --json name,status,conclusion,createdAt,url)"
  print_run_summary "$run_json"

  # Job + step breakdown
  local jobs_json
  jobs_json="$(gh run view "$run_id" --json jobs --jq '.jobs')"

  local job_count failed_count
  job_count=$(jq 'length' <<< "$jobs_json")
  failed_count=$(jq '[.[] | select(.conclusion == "failure")] | length' <<< "$jobs_json")

  printf "\033[2mJobs: %s total, %s failed\033[0m\n\n" "$job_count" "$failed_count"

  # Print each job + its steps (filtered unless --all)
  jq -r --argjson all "$show_all" '
    .[] |
    . as $job |
    "\u001b[1m" + $job.name + "\u001b[0m  " +
    (if   $job.conclusion == "success"  then "\u001b[32m✓\u001b[0m"
     elif $job.conclusion == "failure"  then "\u001b[31m✗\u001b[0m"
     elif $job.conclusion == "skipped"  then "\u001b[2m–\u001b[0m"
     else "\u001b[33m~\u001b[0m" end),

    (($job.steps // [])
     | if $all then . else map(select(.conclusion == "failure")) end
     | .[]
     | "  " +
       (if   .conclusion == "success" then "\u001b[32m✓\u001b[0m"
        elif .conclusion == "failure" then "\u001b[31m✗\u001b[0m"
        elif .conclusion == "skipped" then "\u001b[2m–\u001b[0m"
        else "\u001b[33m~\u001b[0m" end) +
       " " + .name
    ),
    ""
  ' <<< "$jobs_json"

  # For each failed job, fetch and print its logs
  local failed_jobs
  failed_jobs=$(jq -r '[.[] | select(.conclusion == "failure") | .databaseId] | .[]' <<< "$jobs_json")

  if [[ -z "$failed_jobs" && "$show_all" == "false" ]]; then
    printf "\033[2mNo failed steps.\033[0m\n"
    return
  fi

  if [[ -n "$failed_jobs" ]]; then
    printf "\033[1;31m━━━ Failed step logs ━━━\033[0m\n\n"
    while IFS= read -r job_id; do
      local job_name
      job_name=$(jq -r --argjson id "$job_id" '.[] | select(.databaseId == $id) | .name' <<< "$jobs_json")
      printf "\033[1m%s\033[0m\n" "$job_name"
      gh run view "$run_id" --job "$job_id" --log-failed 2>/dev/null \
        | sed 's/^/  /' \
        || printf "  \033[2m(no log output available)\033[0m\n"
      echo
    done <<< "$failed_jobs"
  fi
}

main "$@"