#!/usr/bin/env bash
#MISE description="Interactive issue creation with taxonomy-enforced label picking"
#MISE alias="ghic"
#MISE dir="{{cwd}}"
set -euo pipefail

TAXONOMY=".github/gh-labels.toml"

# ──────────────────────────────────────────────
# TOML parsing — same bespoke awk as gh:drift
# ──────────────────────────────────────────────

# List all group names in definition order
group_names() {
  awk '
    /^\[groups\./ {
      gsub(/^\[groups\./, ""); gsub(/\].*$/, "")
      print
    }
  ' "$TAXONOMY"
}

group_labels() {
  local group="$1"
  awk -v group="$group" '
    /^\[groups\./ {
      in_group = ($0 == "[groups." group "]")
      next
    }
    /^\[/ { in_group=0 }
    in_group && /name\s*=/ {
      gsub(/.*=\s*"|"\s*$/, ""); print
    }
  ' "$TAXONOMY"
}

group_meta() {
  local group="$1" field="$2"
  awk -v group="$group" -v field="$field" '
    /^\[groups\./ {
      in_group = ($0 == "[groups." group "]")
      next
    }
    /^\[groups\./ { in_group=0 }
    in_group && $0 ~ field"\\s*=\\s*true" { print "true"; exit }
  ' "$TAXONOMY"
}

# ──────────────────────────────────────────────
# gum helpers
# ──────────────────────────────────────────────

gum_input() {
  local placeholder="$1" value="${2:-}"
  gum input \
    --placeholder "$placeholder" \
    --value "$value" \
    --width 72 \
    --prompt "> " \
    --prompt.foreground="12"
}

gum_write() {
  local header="$1"
  gum write \
    --header "$header" \
    --header.foreground="12" \
    --placeholder "Supports markdown and paste. Leave empty to skip." \
    --width 72 \
    --height 10 \
    --char-limit 0
}

# ──────────────────────────────────────────────
# Label picking — reads groups from taxonomy
# ──────────────────────────────────────────────

pick_labels() {
  local -a selected_labels=()

  while IFS= read -r group; do
    local required exclusive
    required=$(group_meta "$group" "required")
    exclusive=$(group_meta "$group" "exclusive")

    # Load labels for this group
    local -a labels=()
    while IFS= read -r lbl; do
      [[ -n "$lbl" ]] && labels+=("$lbl")
    done < <(group_labels "$group")

    [[ ${#labels[@]} -eq 0 ]] && continue

    # Skip optional groups unless user opts in
    if [[ "$required" != "true" ]]; then
      gum confirm \
        "Add a $(gum style --bold "$group") label?  (optional)" \
        --affirmative="Yes" --negative="Skip" --default=false \
        || continue
    fi

    local header
    if [[ "$exclusive" == "true" ]]; then
      header="$(gum style --bold "$group")  (pick one)"
    else
      header="$(gum style --bold "$group")  (pick one or more)"
    fi

    if [[ "$exclusive" == "true" ]]; then
      # Single select
      local chosen
      chosen=$(
        printf '%s\n' "${labels[@]}" \
          | gum choose \
              --header "$header" \
              --header.foreground="8" \
              --cursor.foreground="12"
      ) || continue
      [[ -n "$chosen" ]] && selected_labels+=("$chosen")
    else
      # Multi select
      local -a chosen_multi=()
      local raw
      raw=$(
        printf '%s\n' "${labels[@]}" \
          | gum choose --no-limit \
              --header "$header" \
              --header.foreground="8" \
              --cursor.foreground="12" \
              --selected.foreground="10"
      ) || continue

      while IFS= read -r l; do
        [[ -n "$l" ]] && chosen_multi+=("$l")
      done <<< "$raw"
      selected_labels+=("${chosen_multi[@]:-}")
    fi

  done < <(group_names)

  # Return newline-separated list
  printf '%s\n' "${selected_labels[@]:-}"
}

# ──────────────────────────────────────────────
# Title builder — structured or plain
# ──────────────────────────────────────────────

pick_title() {
  gum style --faint \
    "Format: (scope)[X.Y.Z] Description" \
    "  scope = service/layer   e.g. auth · bff · packages/ui" \
    "  ref   = work breakdown  e.g. 1.0 epic · 1.3 story · 1.3.2 task" \
    "  Depth cap: three levels max. Use [X.0] for epics."
  echo

  local structured=false
  gum confirm "Use structured title?" \
    --affirmative="(scope)[X.Y.Z]" \
    --negative="Plain title" \
    --default=true && structured=true || true

  local title=""

  if [[ "$structured" == "true" ]]; then
    local scope="" ref="" description=""

    while [[ -z "$scope" ]]; do
      scope=$(gum input \
        --placeholder "scope  (e.g. auth, bff, packages/ui)" \
        --prompt "> " --prompt.foreground="12" --width 40)
      [[ -z "$scope" ]] && gum style --foreground="9" "Scope is required for structured titles."
    done

    while [[ -z "$ref" ]]; do
      ref=$(gum input \
        --placeholder "ref  (e.g. 1.0  1.3  1.3.2)" \
        --prompt "> " --prompt.foreground="12" --width 20)
      # Validate format
      if [[ -n "$ref" ]] && ! [[ "$ref" =~ ^[0-9]+(\.[0-9]+)*$ ]]; then
        gum style --foreground="9" "Invalid ref — use digits and dots only (e.g. 1.3 or 1.3.2)"
        ref=""
      fi
      # Warn on depth > 3
      local depth
      depth=$(echo "$ref" | tr -cd '.' | wc -c)
      if [[ "$depth" -gt 2 ]]; then
        gum style --foreground="11" \
          "Warning: depth ${depth} exceeds the three-level cap. Consider flattening."
      fi
    done

    description=$(gum input \
      --placeholder "description" \
      --prompt "> " --prompt.foreground="12" --width 60)

    title="(${scope})[${ref}] ${description}"
  else
    while [[ -z "$title" ]]; do
      title=$(gum input \
        --placeholder "Title  (required)" \
        --prompt "> " --prompt.foreground="12" --width 72)
      [[ -z "$title" ]] && gum style --foreground="9" "Title is required."
    done
  fi

  echo "$title"
}



pick_milestone() {
  local milestones
  milestones=$(gh milestone list --json title --jq '.[].title' 2>/dev/null || echo "")

  if [[ -z "$milestones" ]]; then
    gum style --foreground="8" --faint "  (no milestones available)"
    return 0
  fi

  local chosen
  chosen=$(
    printf '%s\n' "(none)" "$milestones" \
      | gum choose \
          --header "Milestone  (optional)" \
          --header.foreground="8" \
          --cursor.foreground="12"
  ) || return 0

  [[ "$chosen" == "(none)" ]] && return 0
  echo "$chosen"
}

# ──────────────────────────────────────────────
# Assignee picker
# ──────────────────────────────────────────────

pick_assignee() {
  local collaborators
  collaborators=$(
    gh api "repos/{owner}/{repo}/collaborators" \
      --jq '.[].login' 2>/dev/null || echo ""
  )

  if [[ -z "$collaborators" ]]; then
    gum style --foreground="8" --faint "  (cannot fetch collaborators)"
    return 0
  fi

  local chosen
  chosen=$(
    printf '%s\n' "(none)" "$collaborators" \
      | gum choose \
          --header "Assignee  (optional)" \
          --header.foreground="8" \
          --cursor.foreground="12"
  ) || return 0

  [[ "$chosen" == "(none)" ]] && return 0
  echo "$chosen"
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

main() {
  if ! command -v gum &>/dev/null; then
    echo "error: gum is not installed — run: mise use -g gum" >&2; exit 1
  fi

  if [[ ! -f "$TAXONOMY" ]]; then
    echo "error: $TAXONOMY not found — run from repo root" >&2; exit 1
  fi

  gum style --bold --foreground="12" "Create issue"
  echo

  # ── Title ───────────────────────────────────
  gum style --bold --foreground="11" "Title"
  local title
  title=$(pick_title)
  [[ -z "$title" ]] && { echo "Aborted." >&2; exit 0; }

  # ── Body ────────────────────────────────────
  local body
  body=$(gum_write "Body  (optional — context, acceptance criteria, markdown)")

  # ── Labels ──────────────────────────────────
  echo
  gum style --bold --foreground="11" "Labels"
  local labels_raw
  labels_raw=$(pick_labels)

  # ── Milestone ───────────────────────────────
  echo
  gum style --bold --foreground="11" "Milestone"
  local milestone
  milestone=$(pick_milestone)

  # ── Assignee ────────────────────────────────
  echo
  gum style --bold --foreground="11" "Assignee"
  local assignee
  assignee=$(pick_assignee)

  # ── Preview ─────────────────────────────────
  echo
  gum style --border=rounded --border-foreground="12" --padding="1 2" --bold \
    "Issue preview"
  echo
  gum style --bold --foreground="15" "$title"
  [[ -n "$milestone"  ]] && gum style --foreground="8"  "Milestone : $milestone"
  [[ -n "$assignee"   ]] && gum style --foreground="8"  "Assignee  : $assignee"
  if [[ -n "$labels_raw" ]]; then
    local labels_display
    labels_display=$(echo "$labels_raw" | tr '\n' ',' | sed 's/,$//')
    gum style --foreground="8" "Labels    : $labels_display"
  fi
  if [[ -n "$body" ]]; then
    echo
    gum style --foreground="7" "$body"
  fi
  echo

  gum confirm "Create issue?" \
    --affirmative="Create" --negative="Abort" || { echo "Aborted." >&2; exit 0; }

  # ── Assemble gh issue create call ───────────
  local -a gh_args=(issue create --title "$title")

  [[ -n "$body"      ]] && gh_args+=(--body      "$body")
  [[ -n "$milestone" ]] && gh_args+=(--milestone "$milestone")
  [[ -n "$assignee"  ]] && gh_args+=(--assignee  "$assignee")

  while IFS= read -r lbl; do
    [[ -n "$lbl" ]] && gh_args+=(--label "$lbl")
  done <<< "${labels_raw:-}"

  # ── Create ──────────────────────────────────
  local url
  url=$(gh "${gh_args[@]}")

  echo
  gum style --foreground="10" --bold "✓ Issue created"
  gum style --foreground="8" "$url"
}

main "$@"