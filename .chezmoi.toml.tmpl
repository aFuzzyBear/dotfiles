{{- $osID := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osID = .chezmoi.osRelease.id -}}
{{- end -}}

{{/* Platform context detection — filesystem and kernel markers only.
     Verified against Gabe's running Lima VM on 2026-04-22:
       hostname          → lima-ubuntu
       systemd-detect-virt → apple
     /mnt/lima-cidata and /etc/cloud/cloud.cfg.d/90_lima.cfg
     do not exist in current Lima releases — do not use.

     Precedence: container beats WSL. A container running on the WSL2
     kernel (wslc) matches the microsoft /proc/version string, but the
     kernel identifies the HOST, not the environment. Verified in a wslc
     container 2026-07-12: /.dockerenv present, /proc/version microsoft.
     systemd-detect-virt is guarded — minimal containers have no systemd. */}}
{{- $isWSL := false -}}
{{- $isContainer := false -}}
{{- $isLima := false -}}

{{- if eq .chezmoi.os "linux" -}}
{{-   if or (stat "/.dockerenv") (env "FUZZYOS_CONTAINER") -}}
{{-     $isContainer = true -}}
{{-   end -}}
{{-   if and (not $isContainer) (stat "/proc/version") -}}
{{-     if regexMatch "(microsoft|WSL)" (include "/proc/version") -}}
{{-       $isWSL = true -}}
{{-     end -}}
{{-   end -}}
{{/*   Lima detection: hostname prefix OR Apple hypervisor.
       Either signal on its own is sufficient. */}}
{{-   $virt := "" -}}
{{-   if lookPath "systemd-detect-virt" -}}
{{-     $virt = output "systemd-detect-virt" | trim -}}
{{-   end -}}
{{-   if or (hasPrefix "lima-" .chezmoi.hostname) (eq $virt "apple") -}}
{{-     $isLima = true -}}
{{-   end -}}
{{- end -}}

[data]
    isWSL       = {{ $isWSL }}
    isContainer = {{ $isContainer }}
    isLima      = {{ $isLima }}
    osid        = {{ $osID | quote }}
    hostname    = {{ .chezmoi.hostname | quote }}