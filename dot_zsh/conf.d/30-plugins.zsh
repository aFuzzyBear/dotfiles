# ── Plugins ───────────────────────────────────────────────────────────────────
# fzf-tab must be sourced AFTER compinit (03-completions.zsh)
source ~/.zsh/plugins/fzf-tab/fzf-tab.plugin.zsh

# Autosuggestions: async, lightweight
source ~/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

# History substring search (Up/Down arrow filtering)
source ~/.zsh/plugins/zsh-history-substring-search/zsh-history-substring-search.zsh

# Alias coaching (optional but delightful)
source ~/.zsh/plugins/zsh-you-should-use/you-should-use.plugin.zsh

# Syntax highlighting: must be last - otherwise it will highlight other plugins' output
# Note: this plugin is a fork of the original zsh-syntax-highlighting, with a focus on speed and performance.
source ~/.zsh/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

