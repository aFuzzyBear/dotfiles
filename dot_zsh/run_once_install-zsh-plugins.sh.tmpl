#!/usr/bin/env bash
set -euo pipefail

# ── Plugin directory ───────────────────────────────────────────────────────────
PLUGIN_DIR="$HOME/.zsh/plugins"
mkdir -p "$PLUGIN_DIR"

# ── Helper: clone or update a plugin ──────────────────────────────────────────
install_plugin() {
  local repo="$1"
  local target="$PLUGIN_DIR/$2"

  if [ -d "$target/.git" ]; then
    echo "Updating $2..."
    git -C "$target" pull --ff-only
  else
    echo "Installing $2..."
    git clone --depth=1 "$repo" "$target"
  fi
}

# ── Core plugins ──────────────────────────────────────────────────────────────
install_plugin "https://github.com/Aloxaf/fzf-tab" \
  "fzf-tab"

install_plugin "https://github.com/zsh-users/zsh-autosuggestions" \
  "zsh-autosuggestions"

install_plugin "https://github.com/zsh-users/zsh-syntax-highlighting" \
  "zsh-syntax-highlighting"

# ── Optional but recommended plugins ──────────────────────────────────────────
install_plugin "https://github.com/zsh-users/zsh-history-substring-search" \
  "zsh-history-substring-search"

install_plugin "https://github.com/MichaelAquilina/zsh-you-should-use" \
  "zsh-you-should-use"

# If you prefer fast-syntax-highlighting instead of the default:
install_plugin "https://github.com/zdharma-continuum/fast-syntax-highlighting" \
   "fast-syntax-highlighting"

echo "✓ Zsh plugins installed/updated."
